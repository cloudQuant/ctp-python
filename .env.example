# CTP SimNow 测试环境配置
# 请在 https://www.simnow.com.cn 注册账号后填写以下信息
# 复制此文件为 .env 并填入实际值

# === 第一套环境（交易时段，服务时间与实际生产环境一致） ===
# 第一组：182.254.243.31:30001/30011
# 第二组：182.254.243.31:30002/30012
# 第三组：182.254.243.31:30003/30013

# === 第二套环境（7x24，交易日16:00~次日09:00，非交易日16:00~次日12:00） ===
# 182.254.243.31:40001/40011

# 行情前置地址
CTP_MD_FRONT=tcp://182.254.243.31:30011

# 交易前置地址
CTP_TD_FRONT=tcp://182.254.243.31:30001

# 经纪商代码
CTP_BROKER_ID=9999

# SimNow 投资者账号
CTP_USER_ID=your_user_id

# SimNow 密码
CTP_PASSWORD=your_password

# 客户端认证 AppID
CTP_APP_ID=simnow_client_test

# 客户端认证 AuthCode
CTP_AUTH_CODE=0000000000000000

# 测试用合约代码 (选择当前有效合约，如 IF2603, rb2605 等)
CTP_INSTRUMENT=IF2603

# 交易所代码 (CFFEX/SHFE/DCE/CZCE/INE/GFEX)
CTP_EXCHANGE=CFFEX
